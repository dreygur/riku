#!/usr/bin/env bash
# Riku runtime plugin: Node.js
# Handles apps with a package.json.
set -euo pipefail

CMD="${1:-}"
APP_PATH="${RIKU_APP_PATH:-$(pwd)}"

case "$CMD" in
  detect)
    [ -f "$APP_PATH/package.json" ] && exit 0
    exit 1
    ;;

  build)
    cd "$APP_PATH"
    # Prefer nub: a single Rust binary that reads npm/pnpm/bun lockfiles
    # directly (https://nubjs.com). Fall back to npm so servers that have
    # not installed nub yet still deploy.
    if command -v nub >/dev/null 2>&1; then
      has_lock=0
      for lock in package-lock.json pnpm-lock.yaml lock.yaml bun.lock; do
        [ -f "$lock" ] && has_lock=1
      done
      if [ "$has_lock" -eq 1 ]; then
        nub ci --prod
      else
        nub install --prod
      fi
    elif [ -f "package-lock.json" ]; then
      npm ci --production
    else
      npm install --production
    fi
    ;;

  env)
    printf 'NODE_ENV=production\n'
    printf 'PATH=%s/node_modules/.bin:%s\n' "$APP_PATH" "$PATH"
    ;;

  start)
    APP_PATH="${RIKU_APP_PATH:-$(pwd)}"
    if [ -f "$APP_PATH/package.json" ]; then
      # Try to read "main" field from package.json
      main=$(node -e "try{console.log(require('$APP_PATH/package.json').main||'')}catch(e){}" 2>/dev/null || true)
      if [ -n "$main" ]; then
        echo "node $main"
      else
        echo "node index.js"
      fi
    else
      echo "node index.js"
    fi
    ;;

  *)
    echo "Unknown subcommand: $CMD" >&2
    exit 1
    ;;
esac
