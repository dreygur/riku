# start-supervisor.env
#
# The REAL, currently-functional resource-limit mechanism for the
# bad-tenant test. Source this before starting the supervisor so
# ResourceLimits::from_env() (src/supervisor/resource_limits/mod.rs)
# picks these up. These apply to every worker the supervisor spawns,
# not just bad_tenant — there is no per-app isolation in the current
# code, which is itself one of the things this audit is checking.
#
# Usage:
#   set -a; source tests/production_audit/bad_tenant_app/start-supervisor.env; set +a
#   riku supervisor &

export RIKU_MAX_MEMORY_MB=128
export RIKU_MAX_CPU_SECONDS=10
export RIKU_MAX_OPEN_FILES=64
export RIKU_MAX_PROCESSES=8
export RIKU_MAX_FILE_SIZE_MB=64
