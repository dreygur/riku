{
  "name": "@riku/dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "audit:dashboard": "nubx tsx scripts/audit-dashboard.ts",
    "test:unit": "playwright test --project=unit",
    "test:e2e": "playwright test --project=e2e"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "hono": "^4.7.10",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.15",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^22.15.21",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3"
  },
  "packageManager": "nub@0.2.10",
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.2.10",
      "onFail": "warn"
    }
  },
  "allowBuilds": {
    "sharp": true
  }
}
